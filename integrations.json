    {
      "id": "apple",
      "name": "Apple Apps",
      "description": "Reminders, Notes, Calendar, Contacts, Mail (macOS)",
      "icon": "apple",
      "category": "productivity",
      "authType": "enable",
      "mcpServers": {
        "apple": {
          "command": "npx",
          "args": ["-y", "apple-mcp"],
          "envMapping": {}
        }
      },
      "setupSteps": [
        "Click Enable below",
        "Your Mac may ask for permission to access Reminders, Calendar, or Contacts",
        "Click 'Allow' on any permission prompts that appear",
        "Your Apple apps will be accessible — no sign-in needed since you're already logged in on your Mac"
      ]
    },
    {
      "id": "microsoft-365",
      "name": "Microsoft 365",
      "description": "Outlook, OneDrive, Teams, Calendar, Planner",
      "icon": "microsoft",
      "category": "productivity",
      "authType": "token",
      "tokenConfig": {
        "label": "Client ID",
        "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
        "helpUrl": "https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps",
        "scopes": "Mail.Read, Mail.Send, Calendars.ReadWrite, Files.ReadWrite",
        "fields": [
          { "key": "clientId", "label": "Client ID", "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" },
          { "key": "tenantId", "label": "Tenant ID", "placeholder": "common (or your tenant ID)" }
        ]
      },
      "mcpServers": {
        "microsoft365": {
          "command": "npx",
          "args": ["-y", "microsoft365-mcp-server"],
          "envMapping": {
            "MS365_AUTH_MODE": "_static:interactive",
            "MS365_CLIENT_ID": "clientId",
            "MS365_TENANT_ID": "tenantId"
          }
        }
      },
      "setupSteps": [
        "Go to Azure Portal → App registrations → New registration",
        "Name it 'Delt', set redirect URI to http://localhost",
        "Under API permissions, add Microsoft Graph: Mail.Read, Mail.Send, Calendars.ReadWrite, Files.ReadWrite",
        "Copy the Application (client) ID and Directory (tenant) ID",
        "For personal accounts, use 'common' as the Tenant ID"
      ]
    },
    {
      "id": "twilio",
      "name": "Twilio",
      "description": "SMS, calls, WhatsApp, phone numbers",
      "icon": "twilio",
      "category": "communication",
      "authType": "token",
      "tokenConfig": {
        "label": "Account SID",
        "placeholder": "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://console.twilio.com",
        "scopes": "messaging, voice",
        "fields": [
          { "key": "accountSid", "label": "Account SID", "placeholder": "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" },
          { "key": "authToken", "label": "Auth Token", "placeholder": "Your auth token" },
          { "key": "phoneNumber", "label": "Twilio Phone Number", "placeholder": "+1234567890" }
        ]
      },
      "mcpServers": {
        "twilio": {
          "command": "npx",
          "args": ["-y", "twilio-mcp"],
          "envMapping": {
            "TWILIO_ACCOUNT_SID": "accountSid",
            "TWILIO_AUTH_TOKEN": "authToken",
            "TWILIO_PHONE_NUMBER": "phoneNumber"
          }
        }
      },
      "setupSteps": [
        "Go to console.twilio.com and sign in",
        "Your Account SID and Auth Token are on the dashboard",
        "Click 'Show' next to Auth Token and copy it",
        "Copy a phone number from Phone Numbers → Manage → Active numbers"
      ]
    },
    {
      "id": "sendgrid",
      "name": "SendGrid",
      "description": "Email delivery, templates, analytics",
