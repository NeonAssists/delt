    {
      "id": "zoom",
      "name": "Zoom",
      "description": "Meetings, recordings, participants",
      "icon": "zoom",
      "category": "communication",
      "authType": "token",
      "tokenConfig": {
        "label": "Account ID",
        "placeholder": "Your Zoom account ID",
        "helpUrl": "https://marketplace.zoom.us/develop/create",
        "scopes": "meeting:read, meeting:write",
        "fields": [
          { "key": "accountId", "label": "Account ID", "placeholder": "Your Zoom account ID" },
          { "key": "clientId", "label": "Client ID", "placeholder": "Your Zoom client ID" },
          { "key": "clientSecret", "label": "Client Secret", "placeholder": "Your Zoom client secret" }
        ]
      },
      "mcpServers": {
        "zoom": {
          "command": "npx",
          "args": ["-y", "zoom-mcp-server"],
          "envMapping": {
            "ZOOM_ACCOUNT_ID": "accountId",
            "ZOOM_CLIENT_ID": "clientId",
            "ZOOM_CLIENT_SECRET": "clientSecret"
          }
        }
      },
      "setupSteps": [
        "Go to marketplace.zoom.us and sign in",
        "Click Develop → Build App → Server-to-Server OAuth",
        "Name it 'Delt' and create the app",
        "Copy the Account ID, Client ID, and Client Secret",
        "Add scopes: meeting:read, meeting:write, then activate the app"
      ]
    },
