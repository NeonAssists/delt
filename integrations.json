{
  "integrations": [
    {
      "id": "local-access",
      "name": "Local Computer",
      "description": "Files, folders, and system access on this Mac",
      "icon": "computer",
      "category": "system",
      "authType": "local-access",
      "mcpServers": {
        "filesystem": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-filesystem"],
          "envMapping": {}
        }
      },
      "setupSteps": []
    },
    {
      "id": "google-workspace",
      "name": "Google Workspace",
      "description": "Gmail, Calendar, Sheets, Drive",
      "icon": "google",
      "category": "productivity",
      "authType": "oauth2",
      "oauth": {
        "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
        "tokenUrl": "https://oauth2.googleapis.com/token",
        "scopes": [
          "https://www.googleapis.com/auth/gmail.modify",
          "https://www.googleapis.com/auth/gmail.compose",
          "https://www.googleapis.com/auth/gmail.readonly",
          "https://www.googleapis.com/auth/gmail.labels",
          "https://www.googleapis.com/auth/calendar",
          "https://www.googleapis.com/auth/calendar.events",
          "https://www.googleapis.com/auth/spreadsheets",
          "https://www.googleapis.com/auth/drive.readonly",
          "https://www.googleapis.com/auth/drive.file"
        ]
      },
      "mcpServers": {
        "gmail": {
          "command": "npx",
          "args": ["-y", "@monsoft/mcp-gmail"],
          "envMapping": {}
        },
        "google-calendar": {
          "command": "npx",
          "args": ["-y", "mcp-google-calendar"],
          "envMapping": {}
        },
        "google-sheets": {
          "command": "npx",
          "args": ["-y", "mcp-google-sheets"],
          "envMapping": {}
        }
      },
      "setupSteps": [
        "Click 'Sign in with Google' below",
        "Choose your Google account and grant access",
        "Gmail, Calendar, Sheets, and Drive will all be available"
      ]
    },
    {
      "id": "github",
      "name": "GitHub",
      "description": "Repos, issues, pull requests, code search",
      "icon": "github",
      "category": "development",
      "authType": "token",
      "tokenConfig": {
        "label": "Personal Access Token",
        "placeholder": "ghp_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://github.com/settings/tokens?type=beta",
        "scopes": "repo, read:org, read:user"
      },
      "mcpServers": {
        "github": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-github"],
          "envMapping": { "GITHUB_PERSONAL_ACCESS_TOKEN": "token" }
        }
      },
      "setupSteps": [
        "If you have GitHub CLI (gh) installed, your token is detected automatically — just click Connect",
        "Otherwise: go to github.com → Settings → Developer Settings → Personal Access Tokens",
        "Click 'Generate new token', name it 'Delt', select repo access",
        "Copy the token and paste it below"
      ]
    },
    {
      "id": "slack",
      "name": "Slack",
      "description": "Messages, channels, search workspace",
      "icon": "slack",
      "category": "communication",
      "authType": "token",
      "tokenConfig": {
        "label": "Bot User OAuth Token",
        "placeholder": "xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx",
        "helpUrl": "https://api.slack.com/apps",
        "scopes": "channels:read, chat:write, users:read"
      },
      "mcpServers": {
        "slack": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-slack"],
          "envMapping": { "SLACK_BOT_TOKEN": "token" }
        }
      },
      "setupSteps": [
        "Go to api.slack.com/apps and sign in",
        "Click 'Create New App' → 'From scratch'",
        "Name it 'Delt' and pick your workspace",
        "Go to 'OAuth & Permissions', add scopes: channels:read, chat:write, users:read",
        "Install to Workspace and copy the Bot User OAuth Token"
      ]
    },
    {
      "id": "notion",
      "name": "Notion",
      "description": "Pages, databases, search, create content",
      "icon": "notion",
      "category": "productivity",
      "authType": "token",
      "tokenConfig": {
        "label": "Integration Token",
        "placeholder": "ntn_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://www.notion.so/profile/integrations",
        "scopes": "read, update, insert"
      },
      "mcpServers": {
        "notion": {
          "command": "npx",
          "args": ["-y", "@notionhq/notion-mcp-server"],
          "envMapping": { "OPENAPI_MCP_HEADERS": "token" }
        }
      },
      "setupSteps": [
        "Go to notion.so/profile/integrations",
        "Click 'New integration' and name it 'Delt'",
        "Select your workspace and click Submit",
        "Copy the Internal Integration Token",
        "Go to the Notion pages you want accessible, click ··· → Connections → Add Delt"
      ]
    },
    {
      "id": "linear",
      "name": "Linear",
      "description": "Issues, projects, teams, roadmaps",
      "icon": "linear",
      "category": "development",
      "authType": "token",
      "tokenConfig": {
        "label": "Personal API Key",
        "placeholder": "lin_api_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://linear.app/settings/account/api",
        "scopes": "read, write"
      },
      "mcpServers": {
        "linear": {
          "command": "npx",
          "args": ["-y", "mcp-linear"],
          "envMapping": { "LINEAR_API_KEY": "token" }
        }
      },
      "setupSteps": [
        "Go to Linear → Settings → Account → API",
        "Click 'Create key' under Personal API Keys",
        "Name it 'Delt' and click Create",
        "Copy the key"
      ]
    },
    {
      "id": "stripe",
      "name": "Stripe",
      "description": "Payments, customers, invoices, subscriptions",
      "icon": "stripe",
      "category": "finance",
      "authType": "token",
      "tokenConfig": {
        "label": "Secret Key",
        "placeholder": "sk_test_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://dashboard.stripe.com/apikeys",
        "scopes": "read, write"
      },
      "mcpServers": {
        "stripe": {
          "command": "npx",
          "args": ["-y", "@stripe/mcp"],
          "envMapping": { "STRIPE_SECRET_KEY": "token" }
        }
      },
      "setupSteps": [
        "Go to dashboard.stripe.com and sign in",
        "Click Developers → API Keys",
        "Copy your Secret key (starts with sk_test_ or sk_live_)"
      ]
    },
    {
      "id": "shopify",
      "name": "Shopify",
      "description": "Products, orders, customers, inventory",
      "icon": "shopify",
      "category": "commerce",
      "authType": "token",
      "tokenConfig": {
        "label": "Admin API Access Token",
        "placeholder": "shpat_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://admin.shopify.com/settings/apps/development",
        "scopes": "read_products, write_products, read_orders"
      },
      "mcpServers": {
        "shopify": {
          "command": "npx",
          "args": ["-y", "shopify-mcp"],
          "envMapping": { "SHOPIFY_ACCESS_TOKEN": "token" }
        }
      },
      "setupSteps": [
        "Go to your Shopify Admin → Settings → Apps → Develop apps",
        "Create an app named 'Delt'",
        "Select API scopes and install",
        "Copy the Admin API access token"
      ]
    },
    {
      "id": "hubspot",
      "name": "HubSpot",
      "description": "CRM, contacts, deals, tickets",
      "icon": "hubspot",
      "category": "crm",
      "authType": "token",
      "tokenConfig": {
        "label": "Private App Access Token",
        "placeholder": "pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
        "helpUrl": "https://app.hubspot.com/private-apps/",
        "scopes": "crm.objects.contacts, crm.objects.deals"
      },
      "mcpServers": {
        "hubspot": {
