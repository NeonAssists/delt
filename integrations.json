{
  "integrations": [
    {
      "id": "google-workspace",
      "name": "Google Workspace",
      "description": "Gmail, Drive, Calendar, Contacts, Sheets",
      "icon": "google",
      "category": "productivity",
      "authType": "enable",
      "mcpServers": {
        "google-drive": {
          "command": "npx",
          "args": ["-y", "@anthropic-ai/google-drive-mcp"],
          "envMapping": {}
        }
      },
      "setupSteps": [
        "Click Enable below",
        "The first time you use a Google tool, a browser window will open",
        "Sign in with your Google account and grant access",
        "That's it — authentication is handled automatically"
      ]
    },
    {
      "id": "github",
      "name": "GitHub",
      "description": "Repos, issues, pull requests, code search",
      "icon": "github",
      "category": "development",
      "authType": "token",
      "tokenConfig": {
        "label": "Personal Access Token",
        "placeholder": "ghp_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://github.com/settings/tokens?type=beta",
        "scopes": "repo, read:org, read:user"
      },
      "mcpServers": {
        "github": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-github"],
          "envMapping": { "GITHUB_PERSONAL_ACCESS_TOKEN": "token" }
        }
      },
      "setupSteps": [
        "Open GitHub and go to Settings → Developer Settings → Personal Access Tokens",
        "Click 'Generate new token' and choose Fine-grained or Classic",
        "Give it a name like 'Delt' and select the repos you want to access",
        "Click 'Generate token' at the bottom of the page",
        "Copy the token immediately — you won't see it again"
      ]
    },
    {
      "id": "slack",
      "name": "Slack",
      "description": "Messages, channels, search workspace",
      "icon": "slack",
      "category": "communication",
      "authType": "token",
      "tokenConfig": {
        "label": "Bot User OAuth Token",
        "placeholder": "xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx",
        "helpUrl": "https://api.slack.com/apps",
        "scopes": "channels:read, chat:write, users:read"
      },
      "mcpServers": {
        "slack": {
          "command": "npx",
          "args": ["-y", "@modelcontextprotocol/server-slack"],
          "envMapping": { "SLACK_BOT_TOKEN": "token" }
        }
      },
      "setupSteps": [
        "Go to api.slack.com/apps and sign in",
        "Click 'Create New App' → 'From scratch'",
        "Name it 'Delt' and pick your workspace",
        "Go to 'OAuth & Permissions' in the sidebar, scroll to 'Scopes', and add: channels:read, chat:write, users:read",
        "Scroll up and click 'Install to Workspace', then copy the Bot User OAuth Token"
      ]
    },
    {
      "id": "notion",
      "name": "Notion",
      "description": "Pages, databases, search, create content",
      "icon": "notion",
      "category": "productivity",
      "authType": "token",
      "tokenConfig": {
        "label": "Integration Token",
        "placeholder": "ntn_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://www.notion.so/profile/integrations",
        "scopes": "read, update, insert"
      },
      "mcpServers": {
        "notion": {
          "command": "npx",
          "args": ["-y", "@notionhq/notion-mcp-server"],
          "envMapping": { "OPENAPI_MCP_HEADERS": "token" }
        }
      },
      "setupSteps": [
        "Go to notion.so/profile/integrations",
        "Click 'New integration' and name it 'Delt'",
        "Select your workspace and click Submit",
        "Copy the Internal Integration Token that appears",
        "Important: Go to the Notion pages you want accessible, click ··· → Connections → Add your Delt integration"
      ]
    },
    {
      "id": "linear",
      "name": "Linear",
      "description": "Issues, projects, teams, roadmaps",
      "icon": "linear",
      "category": "development",
      "authType": "token",
      "tokenConfig": {
        "label": "Personal API Key",
        "placeholder": "lin_api_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://linear.app/settings/account/api",
        "scopes": "read, write"
      },
      "mcpServers": {
        "linear": {
          "command": "npx",
          "args": ["-y", "mcp-linear"],
          "envMapping": { "LINEAR_API_KEY": "token" }
        }
      },
      "setupSteps": [
        "Go to Linear → Settings (gear icon) → Account → API",
        "Click 'Create key' under Personal API Keys",
        "Give it a label like 'Delt' and click Create",
        "Copy the key that appears"
      ]
    },
    {
      "id": "stripe",
      "name": "Stripe",
      "description": "Payments, customers, invoices, subscriptions",
      "icon": "stripe",
      "category": "finance",
      "authType": "token",
      "tokenConfig": {
        "label": "Secret Key",
        "placeholder": "sk_test_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://dashboard.stripe.com/apikeys",
        "scopes": "read, write"
      },
      "mcpServers": {
        "stripe": {
          "command": "npx",
          "args": ["-y", "@stripe/mcp"],
          "envMapping": { "STRIPE_SECRET_KEY": "token" }
        }
      },
      "setupSteps": [
        "Go to dashboard.stripe.com and sign in",
        "Click Developers → API Keys in the top nav",
        "Copy your Secret key (starts with sk_test_ or sk_live_)",
        "Tip: use a Test mode key first to try it safely"
      ]
    },
    {
      "id": "shopify",
      "name": "Shopify",
      "description": "Products, orders, customers, inventory",
      "icon": "shopify",
      "category": "commerce",
      "authType": "token",
      "tokenConfig": {
        "label": "Admin API Access Token",
        "placeholder": "shpat_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://admin.shopify.com/settings/apps/development",
        "scopes": "read_products, write_products, read_orders"
      },
      "mcpServers": {
        "shopify": {
          "command": "npx",
          "args": ["-y", "@anthropic-ai/shopify-mcp"],
          "envMapping": { "SHOPIFY_ACCESS_TOKEN": "token" }
        }
      },
      "setupSteps": [
        "Go to your Shopify Admin (your-store.myshopify.com/admin)",
        "Navigate to Settings → Apps and sales channels → Develop apps",
        "Click 'Create an app', name it 'Delt'",
        "Under 'Configuration', select the API scopes you need",
        "Click 'Install app' and copy the Admin API access token"
      ]
    },
    {
      "id": "hubspot",
      "name": "HubSpot",
      "description": "CRM, contacts, deals, tickets",
      "icon": "hubspot",
      "category": "crm",
      "authType": "token",
      "tokenConfig": {
        "label": "Private App Access Token",
        "placeholder": "pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
        "helpUrl": "https://app.hubspot.com/private-apps/",
        "scopes": "crm.objects.contacts, crm.objects.deals"
      },
      "mcpServers": {
        "hubspot": {
          "command": "npx",
          "args": ["-y", "mcp-hubspot"],
          "envMapping": { "HUBSPOT_ACCESS_TOKEN": "token" }
        }
      },
      "setupSteps": [
        "Go to HubSpot → Settings (gear icon) → Account Setup → Integrations → Private Apps",
        "Click 'Create a private app'",
        "Name it 'Delt' and go to the Scopes tab",
        "Select: CRM → Contacts (Read/Write), Deals (Read/Write), Tickets (Read)",
        "Click 'Create app' and copy the access token that appears"
      ]
    },
    {
      "id": "trello",
      "name": "Trello",
      "description": "Boards, cards, lists, checklists",
      "icon": "trello",
      "category": "productivity",
      "authType": "token",
      "tokenConfig": {
        "label": "API Token",
        "placeholder": "your-trello-api-token",
        "helpUrl": "https://trello.com/power-ups/admin",
        "scopes": "read, write"
      },
      "mcpServers": {
        "trello": {
          "command": "npx",
          "args": ["-y", "mcp-trello"],
          "envMapping": { "TRELLO_API_TOKEN": "token" }
        }
      },
      "setupSteps": [
        "Go to trello.com/power-ups/admin and sign in",
        "Click 'New' to create a Power-Up (or use an existing one)",
        "Go to the API Key section and click 'Generate a new API Key'",
        "Then click the 'Token' link next to your key to generate a token",
        "Authorize it and copy the token"
      ]
    },
    {
      "id": "asana",
      "name": "Asana",
      "description": "Tasks, projects, teams, timelines",
      "icon": "asana",
      "category": "productivity",
      "authType": "token",
      "tokenConfig": {
        "label": "Personal Access Token",
        "placeholder": "1/12345678:abcdefxxxxxxxxxx",
        "helpUrl": "https://app.asana.com/0/my-apps",
        "scopes": "read, write"
      },
      "mcpServers": {
        "asana": {
          "command": "npx",
          "args": ["-y", "mcp-asana"],
          "envMapping": { "ASANA_ACCESS_TOKEN": "token" }
        }
      },
      "setupSteps": [
        "Go to Asana → click your profile picture → My Settings",
        "Go to the Apps tab, then click 'Developer console' at the bottom",
        "Click 'Create new token'",
        "Name it 'Delt', agree to the terms, and click Create",
        "Copy the token — you won't be able to see it again"
      ]
    },
    {
      "id": "figma",
      "name": "Figma",
      "description": "Design files, components, comments",
      "icon": "figma",
      "category": "design",
      "authType": "token",
      "tokenConfig": {
        "label": "Personal Access Token",
        "placeholder": "figd_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://www.figma.com/developers/api#access-tokens",
        "scopes": "file:read"
      },
      "mcpServers": {
        "figma": {
          "command": "npx",
          "args": ["-y", "@anthropic-ai/figma-mcp"],
          "envMapping": { "FIGMA_ACCESS_TOKEN": "token" }
        }
      },
      "setupSteps": [
        "Go to figma.com and click your avatar → Settings",
        "Scroll down to 'Personal access tokens'",
        "Click 'Create a new personal access token'",
        "Name it 'Delt', choose an expiration, and click 'Create token'",
        "Copy the token immediately"
      ]
    },
    {
      "id": "microsoft-365",
      "name": "Microsoft 365",
      "description": "Outlook, OneDrive, Teams, Word, Excel",
      "icon": "microsoft",
