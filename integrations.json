    {
      "id": "vscode",
      "name": "VS Code",
      "description": "Workspace files, diagnostics, terminals, editor control",
      "icon": "vscode",
      "category": "development",
      "authType": "enable",
      "mcpServers": {
        "vscode": {
          "command": "npx",
          "args": ["-y", "@vscode-mcp/vscode-mcp-server"],
          "envMapping": {}
        }
      },
      "setupSteps": [
        "Install the 'VSCode MCP' extension in VS Code (search 'vscode-mcp' in the Extensions panel)",
        "Make sure VS Code is running with the extension active",
        "Click Enable below — the MCP server connects to VS Code via Unix Socket",
        "No API keys needed — it talks directly to your running VS Code instance"
      ]
    },
    {
      "id": "airtable",
      "name": "Airtable",
      "description": "Bases, tables, records, views",
      "icon": "airtable",
      "category": "productivity",
      "authType": "token",
      "tokenConfig": {
        "label": "Personal Access Token",
        "placeholder": "pat_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://airtable.com/create/tokens",
        "scopes": "data.records:read, data.records:write"
      },
      "mcpServers": {
        "airtable": {
          "command": "npx",
          "args": ["-y", "mcp-airtable"],
          "envMapping": { "AIRTABLE_API_KEY": "token" }
        }
      },
