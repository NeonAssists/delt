    },
    {
      "id": "figma",
      "name": "Figma",
      "description": "Design files, components, comments",
      "icon": "figma",
      "category": "design",
      "authType": "token",
      "tokenConfig": {
        "label": "Personal Access Token",
        "placeholder": "figd_xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://www.figma.com/developers/api#access-tokens",
