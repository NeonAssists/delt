      "category": "communication",
      "authType": "token",
      "tokenConfig": {
        "label": "API Key",
        "placeholder": "SG.xxxxxxxxxxxxxxxxxxxx",
        "helpUrl": "https://app.sendgrid.com/settings/api_keys",
        "scopes": "mail.send, templates.read"
      },
      "mcpServers": {
        "sendgrid": {
          "command": "npx",
