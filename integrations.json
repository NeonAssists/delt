          "envMapping": {
            "SENDGRID_API_KEY": "token"
          }
        }
      },
      "setupSteps": [
        "Go to app.sendgrid.com → Settings → API Keys",
        "Click 'Create API Key'",
        "Name it 'Delt', choose 'Full Access' or select specific permissions",
        "Click 'Create & View' and copy the key immediately"
      ]
    },
    {
      "id": "salesforce",
      "name": "Salesforce",
      "description": "CRM, leads, opportunities, accounts, reports",
      "icon": "salesforce",
      "category": "crm",
      "authType": "enable",
      "mcpServers": {
        "salesforce": {
          "command": "npx",
          "args": ["-y", "salesforce-mcp-server"],
          "envMapping": {}
